---
import '../styles/global.css';
import MobileMenu from '../components/MobileMenu.astro';
---

<!doctype html>
<html lang="en" class="light sm:scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Brandon Jeremiah Sutedja | UKRIDA Portfolio</title>
    <meta name="description" content="Portfolio of Brandon Jeremiah Sutedja from UKRIDA" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
  </head>
  <body class="bg-background text-on-background selection:bg-primary-container selection:text-on-primary-container">

    {/* Navigation */}
    <nav class="fixed top-4 left-4 right-4 md:top-6 md:left-0 md:right-0 md:w-full z-50 flex justify-between items-center px-5 md:px-6 py-3 max-w-4xl mx-auto rounded-full bg-white/70 backdrop-blur-md shadow-[0_20px_40px_rgba(42,52,57,0.06)]">
      <a href="/" class="flex items-center gap-2 group">
        <div class="relative w-8 h-8">
          <img
            src="/img/logo.png"
            alt="Logo"
            class="absolute inset-0 w-full h-full object-contain transition-opacity duration-300 opacity-100 group-hover:opacity-0"
          />
          <img
            src="/img/logo-hover.png"
            alt="Logo Hover"
            class="absolute inset-0 w-full h-full object-contain transition-opacity duration-300 opacity-0 group-hover:opacity-100"
          />
        </div>
        <span class="text-lg font-bold text-slate-900 tracking-tighter transition-colors duration-300 group-hover:text-primary">
          Brandon Jeremiah
        </span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a
          class="text-primary font-bold font-['Plus_Jakarta_Sans'] text-sm tracking-tight hover:text-primary transition-all duration-300"
          href="#projects"
        >
          Projects
        </a>
        <a
          class="text-slate-500 font-['Plus_Jakarta_Sans'] text-sm font-medium tracking-tight hover:bg-slate-100 hover:text-primary px-3 py-1 rounded-full transition-all duration-300"
          href="#experience"
        >
          Experience
        </a>
        <a
          class="text-slate-500 font-['Plus_Jakarta_Sans'] text-sm font-medium tracking-tight hover:bg-slate-100 hover:text-primary px-3 py-1 rounded-full transition-all duration-300"
          href="#contact"
        >
          Contact
        </a>
      </div>
      <div class="flex items-center gap-2">
        <button class="hidden md:block bg-primary text-on-primary px-5 py-2 rounded-full font-bold text-sm scale-95 active:scale-90 transition-transform">
          Resume
        </button>
        <MobileMenu />
      </div>
    </nav>

    <main class="pt-32 pb-20 px-4 md:px-8 max-w-7xl mx-auto">
      {/* Hero Section */}
      <section class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-40">
        <div class="lg:col-span-8 bg-surface-container-lowest p-6 md:p-16 rounded-3xl flex flex-col justify-center">
          <span class="text-primary font-bold tracking-widest text-xs uppercase mb-6 mt-4 md:mt-0">
            Computer Science @ UKRIDA
          </span>
          <h1 class="text-4xl md:text-7xl font-extrabold text-on-surface tracking-tighter leading-[1.1] mb-8">
            Hi, I&apos;m Brandon. <br />
            <span class="text-outline">
              I build robust backends and software systems.
            </span>
          </h1>
          <p class="text-lg text-on-surface-variant max-w-xl leading-relaxed">
            Software Engineering student at Universitas Kristen Krida Wacana, based in
            Jakarta, Indonesia. I focus on backend architecture, database design, and
            building reliable web services with clean, performant code.
          </p>
          <div class="mt-8 flex items-center gap-6">
            <a
              class="text-outline hover:text-primary transition-colors duration-300"
              href="https://www.linkedin.com/in/brandon-jeremiah-sutedja/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
            >
              <svg
                class="w-8 h-8 fill-current"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
            <a
              class="text-outline hover:text-primary transition-colors duration-300"
              href="https://github.com/stdrouuu"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
            >
              <svg
                class="w-8 h-8 fill-current"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
              </svg>
            </a>
            <a
              class="text-outline hover:text-primary transition-colors duration-300"
              href="https://instagram.com/brandon._js"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              <svg
                class="w-8 h-8 fill-current"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
              </svg>
            </a>
            <a
              class="text-outline hover:text-primary transition-colors duration-300"
              href="https://open.spotify.com/user/eeua467i5c6b9fivr3adqnz2k?si=fjSscfohTymAxnmTPK60BA&pi=hDzNWMoFSB6E7"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Spotify"
            >
              <svg
                class="w-8 h-8 fill-current"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.45 17.336c-.22.361-.692.477-1.053.257-2.887-1.764-6.521-2.164-10.8-1.185-.411.094-.823-.163-.916-.574-.093-.41.163-.823.574-.915 4.673-1.069 8.683-.604 11.938 1.385.36.22.476.691.257 1.052zm1.458-3.242c-.276.448-.865.59-1.314.314-3.328-2.043-8.4-2.673-11.928-1.464-.52.178-1.085-.1-1.263-.619-.178-.52.1-1.085.62-1.263 4.102-1.405 9.7-1.157 13.568 1.218.448.276.59.865.317 1.314zm.14-3.41c-3.997-2.37-10.596-2.589-14.417-1.434-.633.191-1.313-.167-1.503-.799-.191-.632.167-1.313.799-1.503 4.41-1.328 11.678-1.088 16.3 1.655.568.337.755 1.063.418 1.632-.336.568-1.062.755-1.632.418z" />
              </svg>
            </a>
          </div>
        </div>
        <div class="lg:col-span-4 bg-surface-container-low rounded-xl overflow-hidden relative group">
          <img
            alt="Brandon Jeremiah Sutedja"
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
            src="/img/profile1.jpeg"
          />
          <div class="absolute bottom-6 left-6 right-6 p-6 bg-white/60 backdrop-blur-xl rounded-lg">
            <p class="text-sm font-bold text-on-surface">
              Brandon Jeremiah Sutedja
            </p>
            <p class="text-xs text-on-surface-variant uppercase tracking-widest mt-1">
              Software Engineer · Jakarta
            </p>
          </div>
        </div>
      </section>

      {/* Academic & Stats Bento */}
      <section
        class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-6 gap-6 mb-40"
        id="experience"
      >
        <div class="md:col-span-2 lg:col-span-2 bg-surface-container p-8 rounded-3xl flex flex-col h-full min-h-[240px]">
          <i class="ri-graduation-cap-line text-primary text-4xl mb-4"></i>
          <div class="mt-auto">
            <h3 class="text-2xl font-bold mb-2">UKRIDA</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              Bachelor of Computer Science
              <br />
              Expected Graduation 2026
            </p>
          </div>
        </div>
        <div class="md:col-span-2 lg:col-span-2 bg-primary text-on-primary p-8 rounded-3xl flex flex-col h-full min-h-[240px]">
          <div>
            <h3 class="text-5xl font-extrabold mb-1">3.8</h3>
            <p class="text-on-primary/80 text-xs font-bold uppercase tracking-widest">
              Cumulative GPA
            </p>
          </div>
          <div class="mt-auto pt-6 border-t border-white/20">
            <p class="text-sm italic leading-relaxed text-on-primary/90">
              &quot;Passionate about learning new technologies and applying them
              to build real-world applications.&quot;
            </p>
          </div>
        </div>
        <div class="md:col-span-4 lg:col-span-2 bg-surface-container-high p-8 rounded-3xl flex flex-col h-full min-h-[240px] justify-center">
          <h3 class="text-xl font-bold mb-6">Core Stack</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-4 py-2 bg-surface-container-lowest text-primary text-[11px] font-extrabold rounded-full shadow-sm">
              PYTHON
            </span>
            <span class="px-4 py-2 bg-surface-container-lowest text-primary text-[11px] font-extrabold rounded-full shadow-sm">
              REACT
            </span>
            <span class="px-4 py-2 bg-surface-container-lowest text-primary text-[11px] font-extrabold rounded-full shadow-sm">
              TYPESCRIPT
            </span>
            <span class="px-4 py-2 bg-surface-container-lowest text-primary text-[11px] font-extrabold rounded-full shadow-sm">
              POSTGRES
            </span>
            <span class="px-4 py-2 bg-surface-container-lowest text-primary text-[11px] font-extrabold rounded-full shadow-sm">
              DOCKER
            </span>
          </div>
        </div>
      </section>

      {/* Current Technologies Section */}
      <section class="mb-40">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-on-surface tracking-tighter mb-2">
            Current technologies
          </h2>
          <p class="text-on-surface-variant text-sm max-w-2xl leading-relaxed mb-8">
            I'm proficient in a range of modern technologies that empower me to build highly functional solutions. These are some of my main technologies.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          
          <!-- Laravel -->
          <div class="flex items-center gap-4 p-4 bg-white border border-outline-variant/10 rounded-2xl shadow-sm hover:shadow-md hover:border-primary/50 transition-all group duration-300">
            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
              <img
                src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/laravel/laravel-original.svg"
                alt="Laravel"
                class="w-6 h-6"
              />
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-800">Laravel</h4>
              <p class="text-xs text-slate-400 mt-0.5">PHP Web Framework</p>
            </div>
          </div>

          <!-- Python -->
          <div class="flex items-center gap-4 p-4 bg-white border border-outline-variant/10 rounded-2xl shadow-sm hover:shadow-md hover:border-primary/50 transition-all group duration-300">
            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
              <img
                src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg"
                alt="Python"
                class="w-6 h-6"
              />
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-800">Python</h4>
              <p class="text-xs text-slate-400 mt-0.5">Scripting & AI</p>
            </div>
          </div>

          <!-- TypeScript -->
          <div class="flex items-center gap-4 p-4 bg-white border border-outline-variant/10 rounded-2xl shadow-sm hover:shadow-md hover:border-primary/50 transition-all group duration-300">
            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
              <img
                src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg"
                alt="TypeScript"
                class="w-6 h-6"
              />
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-800">TypeScript</h4>
              <p class="text-xs text-slate-400 mt-0.5">JavaScript but better</p>
            </div>
          </div>

          <!-- Vue.js -->
          <div class="flex items-center gap-4 p-4 bg-white border border-outline-variant/10 rounded-2xl shadow-sm hover:shadow-md hover:border-primary/50 transition-all group duration-300">
            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
              <img
                src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vuejs/vuejs-original.svg"
                alt="Vue.js"
                class="w-6 h-6"
              />
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-800">Vue.js</h4>
              <p class="text-xs text-slate-400 mt-0.5">Frontend Framework</p>
            </div>
          </div>

          <!-- PHP -->
          <div class="flex items-center gap-4 p-4 bg-white border border-outline-variant/10 rounded-2xl shadow-sm hover:shadow-md hover:border-primary/50 transition-all group duration-300">
            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
              <img
                src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/php/php-original.svg"
                alt="PHP"
                class="w-6 h-6"
              />
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-800">PHP</h4>
              <p class="text-xs text-slate-400 mt-0.5">Backend Language</p>
            </div>
          </div>

          <!-- MySQL -->
          <div class="flex items-center gap-4 p-4 bg-white border border-outline-variant/10 rounded-2xl shadow-sm hover:shadow-md hover:border-primary/50 transition-all group duration-300">
            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
              <img
                src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg"
                alt="MySQL"
                class="w-6 h-6"
              />
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-800">MySQL</h4>
              <p class="text-xs text-slate-400 mt-0.5">Relational Database</p>
            </div>
          </div>

          <!-- PostgreSQL -->
          <div class="flex items-center gap-4 p-4 bg-white border border-outline-variant/10 rounded-2xl shadow-sm hover:shadow-md hover:border-primary/50 transition-all group duration-300">
            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
              <img
                src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg"
                alt="PostgreSQL"
                class="w-6 h-6"
              />
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-800">PostgreSQL</h4>
              <p class="text-xs text-slate-400 mt-0.5">Advanced Database</p>
            </div>
          </div>

          <!-- Git -->
          <div class="flex items-center gap-4 p-4 bg-white border border-outline-variant/10 rounded-2xl shadow-sm hover:shadow-md hover:border-primary/50 transition-all group duration-300">
            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
              <img
                src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg"
                alt="Git"
                class="w-6 h-6"
              />
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-800">Git</h4>
              <p class="text-xs text-slate-400 mt-0.5">Version Control</p>
            </div>
          </div>

        </div>
      </section>

      {/* Projects Section (Bento Grid) */}
      <section class="mb-40" id="projects">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
          <div>
            <span class="text-primary font-bold tracking-widest text-xs uppercase">
              Portfolio
            </span>
            <h2 class="text-4xl font-bold text-on-surface tracking-tighter mt-2">
              Featured Projects
            </h2>
          </div>
          <p class="text-on-surface-variant max-w-sm text-sm">
            A collection of web and software projects I built while studying
            Computer Science at UKRIDA.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {/* Neural Library Analytics */}
          <div
            class="project-card cursor-pointer md:col-span-2 bg-surface-container-lowest rounded-xl overflow-hidden group border border-outline-variant/10 shadow-sm hover:shadow-xl transition-all duration-500"
            data-title="Library Archive Analytics"
            data-desc="A database system built for the UKRIDA digital archive to search and analyze over 50,000 academic records efficiently."
            data-tech="PostgreSQL, Python, Docker, FastAPI"
            data-features="Sub-second search latency;Automated metadata extraction from PDFs;Analytics dashboard for publication trends;Role-based access control for student thesis papers"
            data-color="#788FEC"
          >
            <div class="flex flex-col lg:flex-row h-full">
              <div class="lg:w-1/2 p-8 md:p-12 flex flex-col justify-between">
                <div>
                  <div class="flex gap-3 mb-8">
                    <i class="ri-database-2-line text-primary text-xl"></i>
                    <span class="text-xs font-bold text-on-surface-variant uppercase tracking-widest self-center">
                      Backend Engineering
                    </span>
                  </div>
                  <h3 class="text-3xl font-extrabold mb-6 tracking-tighter">
                    Library Archive Analytics
                  </h3>
                  <p class="text-on-surface-variant leading-relaxed mb-8">
                    A database system built for the UKRIDA digital archive to search
                    and analyze over 50,000 academic records efficiently.
                  </p>
                </div>
                <span
                  class="inline-flex items-center gap-2 text-primary font-bold group w-fit cursor-pointer"
                >
                  View Case Study
                  <i class="ri-arrow-right-line transition-transform group-hover:translate-x-1"></i>
                </span>
              </div>
              <div class="lg:w-1/2 bg-surface-container-high flex items-center justify-center p-8 lg:p-12 min-h-[350px]">
                <div class="relative w-full h-full max-w-[280px] aspect-square flex items-center justify-center">
                  <img
